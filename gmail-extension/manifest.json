{
  "manifest_version": 3,
  "name": "Gmail Unread Counter",
  "version": "1.0",
  "version_name": "1.0 (2026-02-16 20:54 -0800)",
  "description": "Shows your unread Gmail messages",
  "permissions": ["identity", "storage", "alarms"],
  "host_permissions": ["https://www.googleapis.com/", "https://mail.google.com/*"],
  "action": {
    "default_icon": "icon.svg"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "oauth2": {
    "client_id": "916941878676-t21h7ltsco1kp9pkchmogkcnhd13m62m.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/gmail.readonly"]
  },
  "icons": {
    "128": "icon.svg"
  }
}
